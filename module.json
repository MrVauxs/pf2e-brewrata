{
	"id": "pf2e-brewrata",
	"title": "PF2e Brewrata",
	"description": "A library module for creating homebrew erratas to existing content",
	"authors": [
		{
			"name": "Vauxs",
			"discord": "vauxs",
			"twitter": "@ThatVauxs",
			"email": "mrvauxs@gmail.com",
			"ko-fi": "MrVauxs",
			"patreon": "MrVauxs"
		}
	],
	"version": "dev",
